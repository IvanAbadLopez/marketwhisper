# ============================================
# MarketWhisper - Environment Configuration
# ============================================
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Full documentation: README.md
#
# ============================================

# Database (Docker PostgreSQL - use this for local development)
# Make sure Docker Compose is running: docker compose up db
DATABASE_URL="postgresql://marketwhisper:marketwhisper_dev_2026@localhost:5432/marketwhisper"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="docker-dev-secret-change-in-production-please"

# Financial APIs
FINNHUB_API_KEY=""

# LLM Provider (Groq API for AI analysis)
# Free tier available at https://console.groq.com (1K RPM, 300K TPM)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
