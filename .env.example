# Database (Docker PostgreSQL - use this for local development)
# Make sure Docker Compose is running: docker compose up db
DATABASE_URL="postgresql://marketwhisper:marketwhisper_dev_2026@localhost:5432/marketwhisper"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="docker-dev-secret-change-in-production-please"

# Blog Credentials (NEVER commit real values - only for your private .env.local)
BLOG_ANALYSIS_URL=""
BLOG_ANALYSIS_USER=""
BLOG_ANALYSIS_PASSWORD=""
BLOG_SITUATIONS_URL=""
BLOG_SITUATIONS_USER=""
BLOG_SITUATIONS_PASSWORD=""

# Financial APIs (optional)
FINNHUB_API_KEY=""

# LLM Provider Configuration
# Use "groq" for serverless deployment (requires GROQ_API_KEY) or "ollama" for local (requires Docker)
LLM_PROVIDER="groq"

# Groq API (for serverless deployment - free tier available at https://console.groq.com)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"

# Ollama (for local development - requires Docker Compose)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"
