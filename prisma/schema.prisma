generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ==========================================
// AUTH MODELS (NextAuth.js)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  jobs          Job[]
  companies     Company[]
  analyses      Analysis[]
  enrichments   CompanyEnrichment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// JOB TRACKING SYSTEM
// ==========================================

model Job {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          JobType
  status        JobStatus @default(PENDING)
  ticker        String
  result        Json?
  errorMessage  String?
  analysisId    String?   @unique
  enrichmentId  String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

enum JobType {
  ANALYSIS
  ENRICHMENT
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ==========================================
// SENTIMENT ENUM
// ==========================================

enum Sentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

// ==========================================
// COMPANY MODELS
// ==========================================

model Company {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker               String           // Stock ticker symbol (e.g., AAPL, MSFT)
  name                 String           // Company name (e.g., Apple Inc.)
  description          String?          // Company description
  sector               String?          // Industry sector
  industry             String?          // Specific industry
  marketCap            Float?           // Market capitalization
  logoUrl              String?          // Company logo URL
  website              String?          // Official website
  avgSentimentScore    Float?           // Aggregated sentiment score (-1 to +1)
  avgReliabilityScore  Float?           // Aggregated reliability score (1-10)
  analysisCount        Int              @default(0) // Total number of analyses
  // Valuation fields (computed from formulas)
  globalScore          Float?           // 0-100
  globalScoreLabel     String?          // Strong/Moderate/Neutral/Weak
  targetPrice          Float?           // USD
  valuationBreakdown   Json?            // Detailed calculation breakdown
  valuationUpdatedAt   DateTime?        // Last recalculation timestamp
  analyses             Analysis[]       // AI text analyses
  enrichments          CompanyEnrichment[] // Public data enrichments (Finnhub + Ollama)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([userId, ticker])
  @@index([userId])
  @@index([ticker])
  @@index([sector])
}

// ==========================================
// AI ANALYSIS MODELS
// ==========================================

model Analysis {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  text               String    // Original text input from user
  source             String?   // Optional source name (e.g., "Twitter", "Bloomberg")
  companyId          String    // Detected company
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ticker             String    // Detected ticker symbol
  sentiment          Sentiment // AI-detected sentiment
  reliabilityScore   Int       // AI confidence score (1-10)
  reasoning          String    // AI explanation for the analysis (English)
  financialSnapshot  Json?     // Snapshot of financial data at analysis time (price, P/E, EPS, 52w range, analyst consensus)
  jobId              String?   // Optional job relation for tracking
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([companyId])
  @@index([ticker])
  @@index([createdAt])
  @@index([jobId])
}

// ==========================================
// ENRICHMENT MODELS - Public Financial Data
// ==========================================

model CompanyEnrichment {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ticker          String            // Ticker symbol for reference
  source          EnrichmentSource  @default(FINNHUB) // Data source (Finnhub)
  // Processing status (for background enrichment)
  status          EnrichmentStatus  @default(PENDING)
  errorMessage    String?           // Error detail if status is FAILED
  // Financial data (raw structured data)
  financialData   Json?             // Revenue, EPS, P/E ratio, debt/equity, profit margins, etc.
  priceData       Json?             // Current price, 52-week high/low, volume, day change, etc.
  newsHeadlines   Json?             // Recent news articles with title, publisher, link, date
  recommendations Json?             // Analyst recommendations (strong buy, buy, hold, sell, strong sell)
  // AI Analysis (Ollama-generated insights)
  aiAnalysis      String?           // Comprehensive AI-generated summary and insights (English)
  ollamaModel     String?           // Model used for analysis (e.g., "llama3.1:8b")
  jobId           String?           // Optional job relation for tracking
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([ticker])
  @@index([source])
  @@index([createdAt])
  @@index([status])
  @@index([jobId])
}

enum EnrichmentSource {
  FINNHUB     // Finnhub
}

enum EnrichmentStatus {
  PENDING     // Queued, not started yet
  PROCESSING  // Currently fetching data / generating analysis
  COMPLETED   // Successfully enriched
  FAILED      // Failed (see errorMessage)
}
