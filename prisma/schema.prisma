generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ==========================================
// AUTH MODELS (NextAuth.js)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// CORE MODELS
// ==========================================

model Video {
  id          String      @id @default(cuid())
  title       String
  date        DateTime
  duration    Int         // duration in seconds
  sourceUrl   String?
  localPath   String?
  status      VideoStatus @default(PENDING)
  summary     String?     // AI-generated summary
  transcripts Transcript[]
  mentions    Mention[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum VideoStatus {
  PENDING
  DOWNLOADING
  TRANSCRIBING
  PROCESSING
  COMPLETED
  FAILED
}

model Transcript {
  id        String   @id @default(cuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  text      String
  startTime Float    // seconds from start
  endTime   Float    // seconds from end
  createdAt DateTime @default(now())

  @@index([videoId])
}

model Mention {
  id        String    @id @default(cuid())
  videoId   String
  video     Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  ticker    String
  sentiment Sentiment @default(NEUTRAL)
  context   String    // surrounding text where ticker is mentioned
  timestamp Float     // second in the video
  createdAt DateTime  @default(now())

  @@index([videoId])
  @@index([ticker])
}

enum Sentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

model SpecialSituation {
  id          String          @id @default(cuid())
  title       String
  description String
  date        DateTime
  tickers     String[]
  type        SituationType
  sourceUrl   String?
  status      SituationStatus @default(NEW)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum SituationType {
  OPA
  SPLIT
  MERGER
  ARBITRAGE
  SPINOFF
  DIVIDEND_SPECIAL
  OTHER
}

enum SituationStatus {
  NEW
  REVIEWED
  ACTIVE
  CLOSED
  ARCHIVED
}
