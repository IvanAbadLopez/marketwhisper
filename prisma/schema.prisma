generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ==========================================
// AUTH MODELS (NextAuth.js)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// CORE MODELS - Unified Content System
// ==========================================

model Content {
  id          String           @id @default(cuid())
  title       String
  description String?
  contentType ContentType
  date        DateTime
  sourceUrl   String           @unique // URL where content was scraped from
  sourceName  String           // Display name of source (e.g., "MarketWatch", "TuBlog")
  status      ContentStatus    @default(PENDING)
  summary     String?          // AI-generated summary
  metadata    Json?            // Type-specific data (duration, videoPath, situationType, etc.)
  transcripts Transcript[]
  mentions    Mention[]
  companies   ContentCompany[] // Many-to-many relation with Company
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([contentType])
  @@index([date])
}

enum ContentType {
  VIDEO          // Daily analysis videos
  WEB_ARTICLE    // Scraped web articles
  BLOG_POST      // Blog posts
  SPECIAL_EVENT  // Special situations (mergers, spinoffs, etc.)
  NEWS           // News articles
}

enum ContentStatus {
  PENDING       // Not yet processed
  DOWNLOADING   // Downloading content
  TRANSCRIBING  // Transcribing video
  PROCESSING    // AI processing (extraction, summary)
  COMPLETED     // Fully processed
  FAILED        // Processing failed
}

model Transcript {
  id        String   @id @default(cuid())
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  text      String
  startTime Float?   // seconds from start (null for non-video content)
  endTime   Float?   // seconds from end (null for non-video content)
  createdAt DateTime @default(now())

  @@index([contentId])
}

model Mention {
  id        String    @id @default(cuid())
  contentId String
  content   Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  companyId String?   // Optional relation to Company
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ticker    String    // Kept for backward compatibility
  sentiment Sentiment @default(NEUTRAL)
  context   String    // surrounding text where ticker is mentioned
  timestamp Float?    // second in the video (null for non-video content)
  createdAt DateTime  @default(now())

  @@index([contentId])
  @@index([ticker])
  @@index([companyId])
}

enum Sentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

// ==========================================
// COMPANY MODELS
// ==========================================

model Company {
  id                   String           @id @default(cuid())
  ticker               String           @unique // Stock ticker symbol (e.g., AAPL, MSFT)
  name                 String           // Company name (e.g., Apple Inc.)
  description          String?          // Company description
  sector               String?          // Industry sector
  industry             String?          // Specific industry
  marketCap            Float?           // Market capitalization
  logoUrl              String?          // Company logo URL
  website              String?          // Official website
  avgSentimentScore    Float?           // Aggregated sentiment score (-1 to +1)
  avgReliabilityScore  Float?           // Aggregated reliability score (1-10)
  analysisCount        Int              @default(0) // Total number of analyses
  content              ContentCompany[] // Many-to-many relation with Content
  mentions             Mention[]        // Direct mentions in content
  analyses             Analysis[]       // AI text analyses
  enrichments          CompanyEnrichment[] // Public data enrichments (yfinance + Ollama)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([ticker])
  @@index([sector])
}

model ContentCompany {
  id        String   @id @default(cuid())
  contentId String
  companyId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([contentId, companyId]) // Prevent duplicate relations
  @@index([contentId])
  @@index([companyId])
}

// ==========================================
// AI ANALYSIS MODELS
// ==========================================

model Analysis {
  id               String    @id @default(cuid())
  text             String    // Original text input from user
  source           String?   // Optional source name (e.g., "Twitter", "Bloomberg")
  companyId        String    // Detected company
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ticker           String    // Detected ticker symbol
  sentiment        Sentiment // AI-detected sentiment
  reliabilityScore Int       // AI confidence score (1-10)
  reasoning        String    // AI explanation for the analysis
  createdAt        DateTime  @default(now())

  @@index([companyId])
  @@index([ticker])
  @@index([createdAt])
}

// ==========================================
// ENRICHMENT MODELS - Public Financial Data
// ==========================================

model CompanyEnrichment {
  id              String            @id @default(cuid())
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ticker          String            // Ticker symbol for reference
  source          EnrichmentSource  @default(YAHOO) // Data source (Yahoo Finance or Finnhub)
  // Processing status (for background enrichment)
  status          EnrichmentStatus  @default(PENDING)
  errorMessage    String?           // Error detail if status is FAILED
  // Financial data (raw structured data)
  financialData   Json?             // Revenue, EPS, P/E ratio, debt/equity, profit margins, etc.
  priceData       Json?             // Current price, 52-week high/low, volume, day change, etc.
  newsHeadlines   Json?             // Recent news articles with title, publisher, link, date
  recommendations Json?             // Analyst recommendations (strong buy, buy, hold, sell, strong sell)
  // AI Analysis (Ollama-generated insights)
  aiAnalysis      String?           // Comprehensive AI-generated summary and insights
  ollamaModel     String?           // Model used for analysis (e.g., "llama3.1:8b")
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([ticker])
  @@index([source])
  @@index([createdAt])
  @@index([status])
}

enum EnrichmentSource {
  YAHOO       // Yahoo Finance
  FINNHUB     // Finnhub
}

enum EnrichmentStatus {
  PENDING     // Queued, not started yet
  PROCESSING  // Currently fetching data / generating analysis
  COMPLETED   // Successfully enriched
  FAILED      // Failed (see errorMessage)
}
