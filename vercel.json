{
  "services": {
    "frontend": {
      "root": ".",
      "framework": "nextjs"
    },
    "enrichment": {
      "root": "services/enrichment",
      "entrypoint": "main:app"
    }
  },
  "rewrites": [
    {
      "source": "/api/enrichment(/.*)?",
      "destination": {
        "type": "service",
        "service": "enrichment"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
